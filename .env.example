# TikTok Analyzer Pro Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# API Keys
# ============================================================================
# Get your free Gemini API key from https://aistudio.google.com
GEMINI_API_KEY=

# ============================================================================
# Gemini Configuration
# ============================================================================
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RPM=12
GEMINI_TIMEOUT=30

# ============================================================================
# Whisper Configuration
# ============================================================================
# Model options: tiny, base, small, medium, large (add .en for English-only)
WHISPER_MODEL=small.en

# Device: auto (auto-detect), cuda (GPU), mps (Apple Silicon), cpu
WHISPER_DEVICE=auto

# Compute type: auto (auto-detect), float16 (GPU), int8 (CPU)
WHISPER_COMPUTE_TYPE=auto

# VAD (Voice Activity Detection) settings
WHISPER_VAD_MIN_SILENCE_MS=500
WHISPER_VAD_SPEECH_PAD_MS=200
WHISPER_BEAM_SIZE=3

# ============================================================================
# Video Download Configuration
# ============================================================================
DOWNLOAD_TIMEOUT=15
DOWNLOAD_RETRIES=3
DOWNLOAD_CHECK_CERTIFICATE=true

# ============================================================================
# Flask Web App Configuration
# ============================================================================
FLASK_HOST=localhost
FLASK_PORT=5001
FLASK_DEBUG=false
FLASK_ENV=production

# ============================================================================
# Processing Configuration
# ============================================================================
# Maximum videos to process per profile (0 = unlimited)
MAX_VIDEOS_PER_PROFILE=0

# Minimum transcript length to be considered "substantive"
MIN_TRANSCRIPT_LENGTH=200

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=tiktok_analyzer.log
